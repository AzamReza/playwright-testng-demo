<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SauceDemo Automation Suite"
       verbose="1"
       parallel="false">

    <!-- Global Listener -->
    <listeners>
        <listener class-name="com.bjit.ecauto.listeners.TestListener"/>
    </listeners>

    <!-- ============================== -->
    <!-- ALL TESTS                       -->
    <!-- ============================== -->
    <test name="Login Tests">
        <classes>
            <class name="com.bjit.ecauto.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Products Tests">
        <classes>
            <class name="com.bjit.ecauto.tests.ProductsTest"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.bjit.ecauto.tests.CartTest"/>
        </classes>
    </test>

    <test name="Checkout Tests">
        <classes>
            <class name="com.bjit.ecauto.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>